# Server
PORT=3000
NODE_ENV=development

# MongoDB
DATABASE_URI=mongodb://root:rootpassword@localhost:27017/financial?authSource=admin

# PostgreSQL (pgvector)
POSTGRES_URI=postgresql://postgres:postgres@localhost:5432/financial_vectors

# JWT
JWT_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Embeddings (optional — provider configured at runtime)
EMBEDDING_PROVIDER=mock
EMBEDDING_VECTOR_SIZE=1536

# Integration tests (optional)
RUN_PG_INTEGRATION=false

# Ollama (local LLM for AI agent)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT_MS=60000

# Agent fine-tuning (offline pipeline)
AGENT_FINE_TUNE_ENABLED=false
AGENT_FINE_TUNE_MODEL_TAG=fincontrol-agent
AGENT_FINE_TUNE_MIN_SAMPLES=500
