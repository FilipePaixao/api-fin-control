# Server
PORT=3000
NODE_ENV=development

# MongoDB
DATABASE_URI=mongodb://root:rootpassword@localhost:27017/financial?authSource=admin

# PostgreSQL (pgvector)
POSTGRES_URI=postgresql://postgres:postgres@localhost:5432/financial_vectors

# JWT
JWT_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Embeddings
# Providers: mock | ollama
EMBEDDING_PROVIDER=ollama
EMBEDDING_VECTOR_SIZE=768
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Integration tests (optional)
RUN_PG_INTEGRATION=false

# OpenSearch (Lucene lexical search)
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_INDEX=expenses
OPENSEARCH_REFRESH_ON_WRITE=false

# Ollama (local LLM for AI agent)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT_MS=60000
OLLAMA_NUM_CTX=32768

# Agent fine-tuning (offline pipeline)
AGENT_FINE_TUNE_ENABLED=false
AGENT_FINE_TUNE_MODEL_TAG=fincontrol-agent
AGENT_FINE_TUNE_MIN_SAMPLES=500

# Regional economics (optional — Zoneval API for CEP-level rent data)
ZONEVAL_API_KEY=
ZONEVAL_API_SECRET=
ZONEVAL_BASE_URL=https://api.zoneval.com
REGIONAL_CACHE_TTL_HOURS=168
